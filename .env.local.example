# ── Required ──────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional: Caching (add later for cost savings) ────────────────────────────
# Create a KV database in Vercel dashboard → Storage → KV
# These are auto-filled when you connect KV to your project
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# Create a Blob store in Vercel dashboard → Storage → Blob
# Auto-filled when you connect Blob to your project
# BLOB_READ_WRITE_TOKEN=

# ── Optional: Cache stats endpoint protection ─────────────────────────────────
# Any random string — protects /api/cache-stats from public access
# ADMIN_SECRET=your-secret-here
